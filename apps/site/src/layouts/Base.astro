---
// Base layout for marketing pages (/, /install, /demo, /changelog).
// Docs pages use Starlight's own shell instead.
import '@fontsource/bricolage-grotesque/400.css';
import '@fontsource/bricolage-grotesque/500.css';
import '@fontsource/bricolage-grotesque/600.css';
import '@fontsource/bricolage-grotesque/700.css';
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/jetbrains-mono/500.css';
import '@fontsource/jetbrains-mono/700.css';
import '../styles/tokens.css';
import Icon from '../components/Icon.astro';
import appIconUrl from '../../../../assets/brand/contextcake-app-icon.svg?url';

interface Props {
	title: string;
	description: string;
	tone?: 'dark' | 'paper';
}

const { title, description } = Astro.props;
// Dark is the product default on every marketing route. A visitor can still
// opt into light mode, and that explicit preference remains local to them.
const initialTheme = 'dark';
const isHome = Astro.url.pathname === '/';

// Absolute URLs for canonical + OpenGraph (Astro.site = https://contextcake.com).
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL('/og.png', Astro.site).href;

const repoUrl = 'https://github.com/ContextCake/context-cake';
const year = new Date().getFullYear();

// Footer navigation: every href is a real route (marketing pages + Starlight docs).
const footerColumns = [
	{
		heading: 'Product',
		links: [
			{ label: 'Demo', href: '/demo' },
			{ label: 'Packs', href: '/packs' },
			{ label: 'Pricing', href: '/pricing' },
			{ label: 'Create a Pack', href: '/creators' },
			{ label: 'Install', href: '/install' },
			{ label: 'Changelog', href: '/changelog' },
		],
	},
	{
		heading: 'Documentation',
		links: [
			{ label: 'Overview', href: '/docs' },
			{ label: 'Installation', href: '/docs/getting-started/installation' },
			{ label: 'Your first cascade', href: '/docs/getting-started/first-cascade' },
			{ label: 'MCP tools', href: '/docs/reference/mcp-tools' },
		],
	},
	{
		heading: 'Concepts',
		links: [
			{ label: 'The layer cake', href: '/docs/concepts/layer-cake' },
			{ label: 'Merge semantics', href: '/docs/concepts/merge-semantics' },
			{ label: 'Conflicts & provenance', href: '/docs/concepts/conflicts-and-provenance' },
			{ label: 'The trust boundary', href: '/docs/concepts/trust-boundary' },
		],
	},
];
---

<!doctype html>
<html lang="en" data-cc-theme={initialTheme}>
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="icon" href="/favicon.svg?v=stacked-1" type="image/svg+xml" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<link rel="canonical" href={canonical} />
			<meta property="og:url" content={canonical} />
			<meta property="og:image" content={ogImage} />
			<meta property="og:image:width" content="1200" />
			<meta property="og:image:height" content="630" />
			<meta name="twitter:card" content="summary_large_image" />
			<meta name="twitter:title" content={title} />
			<meta name="twitter:description" content={description} />
			<meta name="twitter:image" content={ogImage} />
	</head>
	<body class="theme-dark" data-default-theme={initialTheme}>
		<script is:inline>
			const themeStorageKey = 'contextcake-site-theme';
			const siteBody = document.body;
			const savedTheme = (() => {
				try {
					return localStorage.getItem(themeStorageKey);
				} catch {
					return null;
				}
			})();
			const initialSiteTheme = savedTheme === 'light' || savedTheme === 'dark'
				? savedTheme
				: siteBody.dataset.defaultTheme;
			document.documentElement.dataset.ccTheme = initialSiteTheme;
			siteBody.classList.toggle('theme-paper', initialSiteTheme === 'light');
			siteBody.classList.toggle('theme-dark', initialSiteTheme === 'dark');
		</script>
		<header class:list={['nav', { 'nav--home': isHome }]}>
			<a href="/" class="brand" aria-label="ContextCake home">
				<img class="brand-mark" src={appIconUrl} alt="" width={isHome ? 50 : 42} height={isHome ? 50 : 42} />
				<span>ContextCake</span>
			</a>
			<nav aria-label="Main">
				<a href="/packs">Packs</a>
				<a href="/pricing">Pricing</a>
				<a href="/docs">Docs</a>
				<a href="/demo">Demo</a>
				<a href="/install">Install</a>
				<a href="https://github.com/ContextCake/context-cake">GitHub</a>
			</nav>
			<button class="theme-toggle" type="button" data-theme-toggle aria-label="Switch to light mode" title="Switch to light mode">
				<Icon name="moon" size={18} class="theme-toggle__moon" />
				<Icon name="sun" size={18} class="theme-toggle__sun" />
				<span class="sr-only">Switch theme</span>
			</button>
		</header>
		<script is:inline>
			const themeToggle = document.querySelector('[data-theme-toggle]');
			const applySiteTheme = (theme, persist = false) => {
				document.documentElement.dataset.ccTheme = theme;
				siteBody.classList.toggle('theme-paper', theme === 'light');
				siteBody.classList.toggle('theme-dark', theme === 'dark');
				themeToggle?.setAttribute('aria-pressed', String(theme === 'dark'));
				const nextTheme = theme === 'dark' ? 'light' : 'dark';
				themeToggle?.setAttribute('aria-label', `Switch to ${nextTheme} mode`);
				themeToggle?.setAttribute('title', `Switch to ${nextTheme} mode`);
				if (persist) {
					try {
						localStorage.setItem(themeStorageKey, theme);
					} catch {
						// A blocked storage area should not prevent a local theme preference.
					}
				}
			};
			applySiteTheme(initialSiteTheme);
			themeToggle?.addEventListener('click', () => {
				applySiteTheme(document.documentElement.dataset.ccTheme === 'dark' ? 'light' : 'dark', true);
			});
		</script>
		<slot />
		<footer class="footer">
			<div class="footer-inner">
				<div class="footer-top">
					<div class="footer-brand">
						<a href="/" class="footer-logo" aria-label="ContextCake home">
							<img class="brand-mark" src={appIconUrl} alt="" width="36" height="36" />
							<span>ContextCake</span>
						</a>
						<p class="footer-tagline">
							Keep company rules, team practices, and personal notes in separate layers.
							ContextCake resolves them without hiding the source or disagreement.
						</p>
						<a class="footer-repo" href={repoUrl} rel="noreferrer">
							<Icon name="github" size={17} strokeWidth={2} />
							<span>Star on GitHub</span>
						</a>
					</div>
					<nav class="footer-nav" aria-label="Footer">
						{footerColumns.map((col) => (
							<div class="footer-col">
								<h2 class="footer-heading">{col.heading}</h2>
								<ul>
									{col.links.map((link) => (
										<li><a href={link.href}>{link.label}</a></li>
									))}
								</ul>
							</div>
						))}
					</nav>
				</div>
				<div class="footer-bottom">
					<p class="footer-legal">
						© {year} ContextCake · Open source, MIT licensed
					</p>
					<p class="footer-motto">Sources and disagreements stay visible.</p>
				</div>
			</div>
		</footer>
	</body>
</html>

<style>
	:global(body) {
		margin: 0;
		min-height: 100vh;
		background:
			radial-gradient(circle at 16% 0%, rgba(141, 195, 168, 0.13), transparent 30%),
			radial-gradient(circle at 82% 14%, rgba(217, 171, 83, 0.11), transparent 28%),
			linear-gradient(180deg, #181914 0%, var(--cc-canvas) 42%, #0b0c0a 100%);
		color: var(--cc-text-body);
		font-family: var(--cc-font-body);
		line-height: 1.6;
	}
	.sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}
	:global(body.theme-paper) {
		color-scheme: light;
	}
	:global(body.theme-dark) {
		color-scheme: dark;
	}
	:global(body::before) {
		content: '';
		position: fixed;
		inset: 0;
		pointer-events: none;
		background-image:
			linear-gradient(rgba(243, 239, 230, 0.025) 1px, transparent 1px),
			linear-gradient(90deg, rgba(243, 239, 230, 0.025) 1px, transparent 1px);
		background-size: 36px 36px;
		mask-image: linear-gradient(to bottom, rgba(0, 0, 0, 0.45), transparent 72%);
	}
	:global(h1, h2, h3) {
		font-family: var(--cc-font-heading);
		color: var(--cc-text);
	}
	:global(a) {
		color: var(--cc-text);
	}
	:global(:focus-visible) {
		outline: 2px solid var(--cc-cta);
		outline-offset: 2px;
	}
	.nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: 0.75rem 1rem;
		position: relative;
		z-index: 1;
		max-width: 76rem;
		margin: 1rem auto 0;
		padding: 0.75rem 0.8rem 0.75rem 1rem;
		background: var(--cc-surface);
		border: 1px solid var(--cc-border);
		border-radius: var(--cc-radius-xl);
		box-shadow: var(--cc-shadow-panel);
		backdrop-filter: blur(18px);
	}
	.brand {
		display: inline-flex;
		align-items: center;
		gap: 0.6rem;
		font-family: var(--cc-font-heading);
		font-weight: 700;
		text-decoration: none;
		color: var(--cc-text);
	}
	.brand-mark {
		display: block;
		flex: none;
		width: 2.6rem;
		height: 2.6rem;
		border-radius: 0.72rem;
		box-shadow: 0 0.35rem 1.15rem rgba(0, 0, 0, 0.26);
	}
	.nav--home .brand-mark {
		width: 3.125rem;
		height: 3.125rem;
	}
	.nav nav {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.25rem;
		padding: 0.25rem;
		border-radius: 999px;
		background: var(--cc-surface-soft);
	}
	@media (max-width: 480px) {
		.nav {
			margin: 0.75rem 0.75rem 0;
			border-radius: 24px;
		}
		.nav nav {
			width: 100%;
			border-radius: 20px;
		}
	}
	.nav nav a {
		display: inline-flex;
		align-items: center;
		min-height: 36px;
		padding: 0 0.8rem;
		border-radius: 999px;
		text-decoration: none;
		color: var(--cc-text-body);
		font-weight: 600;
		transition:
			color var(--cc-transition),
			background var(--cc-transition);
	}
	.nav nav a:hover {
		background: rgba(243, 239, 230, 0.08);
		color: var(--cc-text);
	}
	.theme-toggle {
		display: inline-grid;
		place-items: center;
		flex: none;
		width: 2.75rem;
		height: 2.75rem;
		padding: 0;
		border: 1px solid var(--cc-border);
		border-radius: 50%;
		background: var(--cc-surface-soft);
		color: var(--cc-text);
		cursor: pointer;
		transition: background var(--cc-transition), border-color var(--cc-transition), color var(--cc-transition);
	}
	.theme-toggle:hover {
		border-color: var(--cc-border-strong);
		background: rgba(243, 239, 230, 0.1);
	}
	.theme-toggle__sun {
		display: none;
	}
	:global(html[data-cc-theme='dark']) .theme-toggle__sun {
		display: block;
	}
	:global(html[data-cc-theme='dark']) .theme-toggle__moon {
		display: none;
	}
	.footer {
		position: relative;
		z-index: 1;
		margin-top: 6rem;
		border-top: 1px solid var(--cc-border);
		background: linear-gradient(180deg, transparent, rgba(11, 12, 10, 0.55));
	}
	.footer-inner {
		max-width: 76rem;
		margin: 0 auto;
		padding: 3.5rem 1.5rem 2.25rem;
	}
	.footer-top {
		display: grid;
		grid-template-columns: minmax(0, 1.3fr) minmax(0, 2fr);
		gap: 3rem 2.5rem;
		padding-bottom: 2.5rem;
		border-bottom: 1px solid var(--cc-border);
	}
	.footer-brand {
		max-width: 30rem;
	}
	.footer-logo {
		display: inline-flex;
		align-items: center;
		gap: 0.6rem;
		font-family: var(--cc-font-heading);
		font-size: 1.15rem;
		font-weight: 700;
		text-decoration: none;
		color: var(--cc-text);
	}
	.footer-logo .brand-mark {
		width: 2.2rem;
		height: 2.2rem;
		border-radius: 0.62rem;
	}
	.footer-tagline {
		margin: 1rem 0 1.4rem;
		color: var(--cc-text-body);
		font-size: 0.95rem;
		line-height: 1.6;
	}
	.footer-repo {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.5rem 0.95rem;
		border: 1px solid var(--cc-border);
		border-radius: 999px;
		background: var(--cc-surface-soft);
		color: var(--cc-text-body);
		font-family: var(--cc-font-heading);
		font-weight: 600;
		font-size: 0.88rem;
		text-decoration: none;
		transition:
			border-color var(--cc-transition),
			background var(--cc-transition),
			color var(--cc-transition);
	}
	.footer-repo:hover {
		border-color: var(--cc-border-strong);
		background: rgba(243, 239, 230, 0.08);
		color: var(--cc-text);
	}
	.footer-nav {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 2rem;
	}
	.footer-heading {
		margin: 0 0 0.9rem;
		font-family: var(--cc-font-mono);
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--cc-text-muted);
	}
	.footer-col ul {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 0.6rem;
	}
	.footer-col a {
		color: var(--cc-text-body);
		font-size: 0.92rem;
		text-decoration: none;
		transition: color var(--cc-transition);
	}
	.footer-col a:hover {
		color: var(--cc-text);
	}
	.footer-bottom {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: space-between;
		gap: 0.5rem 1.5rem;
		padding-top: 1.75rem;
		color: var(--cc-text-muted);
		font-size: 0.85rem;
	}
	.footer-legal {
		margin: 0;
	}
	.footer-motto {
		margin: 0;
		font-family: var(--cc-font-mono);
		font-size: 0.8rem;
		color: var(--cc-text-faint);
	}
	@media (max-width: 780px) {
		.footer-top {
			grid-template-columns: 1fr;
			gap: 2.5rem;
		}
	}
	@media (max-width: 480px) {
		.footer-nav {
			grid-template-columns: 1fr 1fr;
			gap: 1.75rem;
		}
	}

	/* Paper marketing variant: the Console's warm default theme, carried into
	   the homepage without changing the dark install/docs-adjacent pages. */
	:global(body.theme-paper) {
		/* Re-map the semantic dark tokens too. Individual page components use
		   these tokens directly, so a surface-only override leaves pale text
		   stranded on a light background. */
		--cc-canvas: #f4f3ea;
		--cc-surface: rgba(255, 253, 246, 0.9);
		--cc-surface-solid: #fffdf6;
		--cc-surface-raised: #fffdf6;
		--cc-surface-soft: rgba(21, 25, 23, 0.055);
		--cc-border: rgba(61, 76, 68, 0.12);
		--cc-border-strong: rgba(61, 76, 68, 0.2);
		--cc-text: #151917;
		--cc-text-body: #313a35;
		--cc-text-muted: #56615a;
		--cc-text-faint: #69716b;
		--cc-cta: #151917;
		--cc-cta-hover: #313a35;
		--cc-on-cta: #fffdf6;
		--cc-shadow-panel: 0 18px 55px rgba(47, 44, 35, 0.08);
		background: var(--cc-page);
		color: var(--cc-ink-body);
	}
	:global(body.theme-paper::before) {
		background-image:
			linear-gradient(var(--cc-paper-line) 1px, transparent 1px),
			linear-gradient(90deg, var(--cc-paper-line) 1px, transparent 1px);
		background-size: 32px 32px;
		opacity: 0.28;
		mask-image: linear-gradient(to bottom, var(--cc-canvas), transparent 44%);
	}
	:global(body.theme-paper h1),
	:global(body.theme-paper h2),
	:global(body.theme-paper h3),
	:global(body.theme-paper a) {
		color: var(--cc-ink);
	}
	:global(body.theme-paper :focus-visible) {
		outline-color: var(--cc-ink);
	}
	.theme-paper .nav {
		max-width: 88rem;
		margin: 0 auto;
		padding: 1rem 1.5rem;
		background: transparent;
		border: 0;
		border-bottom: 1px solid var(--cc-paper-line);
		border-radius: 0;
		box-shadow: none;
		backdrop-filter: none;
	}
	.theme-paper .brand,
	.theme-paper .nav nav a {
		color: var(--cc-ink);
	}
	.theme-paper .nav nav {
		background: transparent;
	}
	.theme-paper .nav nav a:hover {
		background: var(--cc-paper-soft);
		color: var(--cc-ink);
	}
	.theme-paper .theme-toggle {
		border-color: var(--cc-paper-line);
		background: var(--cc-paper-soft);
		color: var(--cc-ink);
	}
	.theme-paper .theme-toggle:hover {
		border-color: var(--cc-paper-line-strong);
		background: var(--cc-paper-line);
	}
	.theme-paper .footer {
		margin-top: 0;
		background: var(--cc-paper);
		border-top-color: var(--cc-paper-line);
	}
	.theme-paper .footer-top {
		border-bottom-color: var(--cc-paper-line);
	}
	.theme-paper .footer-logo,
	.theme-paper .footer-col a,
	.theme-paper .footer-repo {
		color: var(--cc-ink);
	}
	.theme-paper .footer-tagline,
	.theme-paper .footer-heading,
	.theme-paper .footer-bottom,
	.theme-paper .footer-motto {
		color: var(--cc-ink-muted);
	}
	.theme-paper .footer-repo {
		background: var(--cc-paper-soft);
		border-color: var(--cc-paper-line);
	}
	.theme-paper .footer-repo:hover {
		background: var(--cc-paper-line);
		border-color: var(--cc-paper-line-strong);
	}
	@media (max-width: 480px) {
		.theme-paper .nav {
			flex-wrap: nowrap;
			margin: 0;
			padding: 0.65rem 0.8rem;
			border-radius: 0;
		}
		.theme-paper .brand {
			gap: 0.4rem;
			font-size: 0.92rem;
		}
		.theme-paper .brand-mark {
			width: 2.15rem;
			height: 2.15rem;
			border-radius: 0.62rem;
		}
		.theme-paper .nav nav {
			width: auto;
			flex-wrap: nowrap;
			gap: 0;
			padding: 0;
		}
		.theme-paper .nav nav a {
			min-height: 32px;
			padding-inline: 0.38rem;
			font-size: 0.82rem;
		}
		.theme-paper .theme-toggle {
			width: 2.75rem;
			height: 2.75rem;
		}
		.theme-paper .nav nav a:nth-child(4),
		.theme-paper .nav nav a:nth-child(5),
		.theme-paper .nav nav a:nth-child(6) {
			display: none;
		}
	}
</style>
