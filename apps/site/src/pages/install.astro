---
// Install page: the Mac app is the primary activation path. The versioned
// source workflow stays available for evaluators, Linux/WSL users, and audits.
import Base from '../layouts/Base.astro';
import CodeBlock from '../components/CodeBlock.astro';
import Icon from '../components/Icon.astro';
import demo from '../data/demo-cascade.json';

const sourceVersion = '0.2.0';
const sourceTag = `console-v${sourceVersion}`;
const appVersion = '0.1.0';
const appTag = `app-v${appVersion}`;
const archiveName = `context-cake-${sourceTag}.tar.gz`;
const archiveSha256 = '013525569cd3c3cdfac77d22bf1976a1d0bc6e8ffcbdcfbbaa8bd92502bc4253';
const sourceDownloadUrl = `https://github.com/ContextCake/context-cake/archive/refs/tags/${sourceTag}.tar.gz`;
const sourceTagUrl = `https://github.com/ContextCake/context-cake/tree/${sourceTag}`;
const appDownloadUrl = `https://github.com/ContextCake/context-cake/releases/download/${appTag}/ContextCake-${appVersion}-arm64.dmg`;
const appReleaseUrl = `https://github.com/ContextCake/context-cake/releases/tag/${appTag}`;

const terminalDownload = `curl --fail --location ${sourceDownloadUrl} \\
  --output ${archiveName}`;
const githubCliCheckout = `gh repo clone ContextCake/context-cake contextcake -- \\
  --branch ${sourceTag} --depth 1
cd contextcake`;
const gitCheckout = `git clone --branch ${sourceTag} --depth 1 \\
  https://github.com/ContextCake/context-cake.git contextcake
cd contextcake`;
const unpackCommand = `printf '%s  %s\\n' '${archiveSha256}' '${archiveName}' | shasum -a 256 --check &&
mkdir contextcake &&
tar -xzf ${archiveName} -C contextcake --strip-components=1 &&
cd contextcake`;
const resolveCommand = 'node resolver.mjs --manifest playground/manifest.json --concept decisions/primary-db';
const firstPrompt = 'Use ContextCake to list the concepts available to you. Briefly describe the contributing layers, then tell me which project-specific questions you can answer from this context.';

const demoConceptId = 'decisions/primary-db';
const primaryDb = demo.concepts.find((concept) => concept.id === demoConceptId);
if (!primaryDb) throw new Error(`Install demo concept ${demoConceptId} is missing`);

const resolvedChoice = primaryDb.sections.find(
	(section) => section.key === 'choice' && !section.suppressed,
);
if (!resolvedChoice) throw new Error('Install demo choice section is missing');

const conflict = resolvedChoice.conflicts?.[0];
const summarize = (value: string, limit = 108) => {
	const oneLine = value.replace(/\s+/g, ' ').trim();
	return oneLine.length > limit ? `${oneLine.slice(0, limit).trimEnd()}…` : oneLine;
};
const dateFormatter = new Intl.DateTimeFormat('en-US', {
	month: 'short',
	day: 'numeric',
	year: 'numeric',
	timeZone: 'UTC',
});
const formatDate = (iso: string) => dateFormatter.format(new Date(`${iso}T00:00:00Z`));
---

<Base
	tone="dark"
	title="Install ContextCake"
	description="Download ContextCake for Mac, add a Markdown source, and connect your AI agent over local MCP."
>
	<main class="install-page">
		<section class="install-hero" aria-labelledby="install-title">
			<div class="hero-copy">
				<p class="eyebrow">ContextCake for Mac · {appTag}</p>
				<h1 id="install-title">Install the app. Add your knowledge. Ask your agent.</h1>
				<p class="lede">
					ContextCake runs locally on your Mac. Point it at a Markdown folder, connect
					your AI client, and get a sourced answer without building a manifest by hand.
				</p>
				<div class="hero-actions" aria-label="Install actions">
					<a class="button button--primary" href={appDownloadUrl} download>
						<Icon name="download" size={18} />
						Download for Mac
					</a>
					<a class="text-link" href="#source-install">Install from source <span aria-hidden="true">→</span></a>
				</div>
				<ul class="hero-facts" aria-label="Mac app details">
					<li>Signed and notarized</li>
					<li>Apple silicon</li>
					<li>Runs locally</li>
					<li><a href={appReleaseUrl}>Release notes and checksums</a></li>
				</ul>
			</div>

			<figure class="app-preview" aria-labelledby="app-preview-title">
				<div class="window-bar" aria-hidden="true">
					<span></span><span></span><span></span>
					<strong>ContextCake</strong>
				</div>
				<div class="app-shell-preview">
					<div class="preview-sidebar" aria-hidden="true">
						<strong>ContextCake</strong>
						<span class="active">Overview</span>
						<span>Concepts</span>
						<span>Conflicts</span>
					</div>
					<div class="preview-content">
						<p>First source</p>
						<h2 id="app-preview-title">Add your Markdown folder</h2>
						<div class="folder-choice">
							<Icon name="layers" size={18} />
							<div><strong>Markdown folder</strong><span>Recommended · use your existing notes</span></div>
							<span class="selected-mark">✓</span>
						</div>
						<div class="preview-success">
							<span></span>
							<div><strong>Source ready</strong><small>Your cascade has something to answer from.</small></div>
						</div>
						<div class="preview-action"><span>Connect an agent</span><span>→</span></div>
					</div>
				</div>
				<figcaption>The app guides source setup before it connects an agent.</figcaption>
			</figure>
		</section>

		<section class="activation" aria-labelledby="activation-title">
			<header class="section-intro">
				<h2 id="activation-title">From download to a sourced answer.</h2>
				<p>No archive, checksum, or manifest is required for the Mac app.</p>
			</header>

			<ol class="activation-steps">
				<li>
					<span class="step-number">1</span>
					<div class="step-copy">
						<h3>Add a source you already have</h3>
						<p>
							Open the app and choose a Markdown folder. A repository docs folder, Obsidian
							vault, or wiki export works without conversion. You can add more sources later.
						</p>
					</div>
					<div class="step-proof source-proof" aria-label="Example source selection">
						<span>Markdown folder · recommended</span>
						<strong>~/Documents/Work notes</strong>
						<small>.md · .mdx · .txt</small>
					</div>
				</li>

				<li>
					<span class="step-number">2</span>
					<div class="step-copy">
						<h3>Connect the AI client you use</h3>
						<p>
							Choose <strong>Connect an agent</strong> in ContextCake. The app prepares the
							exact local MCP setup and verification steps for your client.
						</p>
					</div>
					<div class="step-proof client-proof" aria-label="Supported AI clients">
						<span>Claude Code</span>
						<span>Codex</span>
						<span>Cursor</span>
						<span>Claude Desktop</span>
						<span>Other MCP</span>
					</div>
				</li>

				<li>
					<span class="step-number">3</span>
					<div class="step-copy">
						<h3>Ask one question and inspect the answer</h3>
						<p>
							Use the first prompt supplied by the app. A good answer names the winning
							source and keeps any disagreement visible.
						</p>
						<CodeBlock lang="text" code={firstPrompt} label="First prompt" copy />
					</div>
					<figure class="result-preview" aria-labelledby="result-title">
						<div class="result-header">
							<div><span>Sourced answer</span><h3 id="result-title">{demoConceptId}</h3></div>
							<span class="result-status"><i></i> resolved</span>
						</div>
						<div class="result-row" style="--result-color: var(--cc-layer-personal)">
							<span class="result-swatch" aria-hidden="true"></span>
							<div><small>Effective choice</small><strong>{summarize(resolvedChoice.content)}</strong></div>
							<code>{resolvedChoice.sourceLayer} · {formatDate(resolvedChoice.sourceUpdated)}</code>
						</div>
						{conflict && (
							<div class="conflict-row">
								<Icon name="alert" size={16} />
								<div><small>Conflict preserved</small><span>{summarize(conflict.content, 78)}</span></div>
								<code>{conflict.layer} · {formatDate(conflict.updated)}</code>
							</div>
						)}
					</figure>
				</li>
			</ol>

			<div class="download-strip">
				<div>
					<strong>Ready to use your own knowledge?</strong>
					<span>ContextCake {appVersion} · Apple silicon</span>
				</div>
				<a class="button button--primary" href={appDownloadUrl} download>
					<Icon name="download" size={18} /> Download the DMG
				</a>
			</div>
		</section>

		<section class="source-install" id="source-install" aria-labelledby="source-title">
			<header class="section-intro section-intro--source">
				<div>
					<h2 id="source-title">Need the engine without the app?</h2>
					<p>
						The versioned source route stays available for Linux, WSL, contribution work,
						and anyone who wants to audit every file before running it.
					</p>
				</div>
				<span>Node.js 18+ · macOS, Linux, or WSL · no npm install</span>
			</header>

			<details class="source-details">
				<summary>
					<span><strong>Show source installation</strong><small>{sourceTag} · archive or Git</small></span>
					<span aria-hidden="true">+</span>
				</summary>
				<div class="source-details-body">
					<section class="source-route" aria-labelledby="archive-title">
						<div class="route-heading">
							<span>Recommended source route</span>
							<h3 id="archive-title">Download and verify the archive</h3>
							<p>The checksum stops the workflow before extraction if the bytes do not match.</p>
						</div>
						<CodeBlock lang="bash" code={terminalDownload} label="Download tagged source" copy />
						<CodeBlock lang="bash" code={unpackCommand} label="Verify and unpack" copy />
						<p class="route-footnote">
							Prefer your browser? <a href={sourceDownloadUrl} download>Download the same .tar.gz</a>,
							then run the verification block above.
						</p>
					</section>

					<section class="source-route" aria-labelledby="git-title">
						<div class="route-heading">
							<span>Source-control route</span>
							<h3 id="git-title">Clone the tagged source</h3>
							<p>Use Git when you want a checkout for inspection, history, or contribution work.</p>
						</div>
						<CodeBlock lang="bash" code={gitCheckout} label="Clone with Git" copy />
						<details class="cli-alternative">
							<summary>Use GitHub CLI instead</summary>
							<CodeBlock lang="bash" code={githubCliCheckout} label="Clone with GitHub CLI" copy />
						</details>
					</section>

					<section class="resolver-proof" aria-labelledby="resolver-title">
						<div>
							<span>Same engine, visible result</span>
							<h3 id="resolver-title">Prove the resolver works</h3>
							<p>Resolve the bundled concept and inspect its winning source and preserved dissent.</p>
						</div>
						<CodeBlock lang="bash" code={resolveCommand} label="Resolve the demo" copy />
					</section>
				</div>
			</details>
		</section>

		<section class="trust" aria-labelledby="trust-title">
			<div>
				<Icon name="shield" size={24} />
				<h2 id="trust-title">Local does not mean automatic trust.</h2>
			</div>
			<div class="trust-copy">
				<p>
					ContextCake reads local files and can launch commands named by a manifest. Only
					add folders and MCP sources you trust. Source installs remain versioned and
					checksum-verifiable for teams that need the smaller audit surface.
				</p>
				<nav aria-label="Install trust links">
					<a href="/docs/concepts/trust-boundary">Read the trust model</a>
					<a href={sourceTagUrl}>Inspect {sourceTag} on GitHub <Icon name="external-link" size={15} /></a>
					<a href="/docs/getting-started/connect-an-agent">Agent connection guide</a>
				</nav>
			</div>
		</section>
	</main>
</Base>

<style>
	.install-page {
		position: relative;
		z-index: 0;
		max-width: 76rem;
		margin: 0 auto;
		padding: 5rem 1.5rem 0;
	}
	.install-hero {
		display: grid;
		grid-template-columns: minmax(0, 0.94fr) minmax(28rem, 1.06fr);
		align-items: center;
		gap: clamp(2.5rem, 6vw, 5.5rem);
		min-height: 35rem;
		padding-bottom: 6rem;
	}
	.eyebrow {
		margin: 0;
		color: var(--cc-layer-team);
		font-family: var(--cc-font-mono);
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.07em;
		text-transform: uppercase;
	}
	h1 {
		max-width: 11ch;
		margin: 1.15rem 0 1.35rem;
		font-size: clamp(3rem, 6vw, 5.6rem);
		line-height: 0.98;
		letter-spacing: -0.035em;
		text-wrap: balance;
	}
	.lede {
		max-width: 39rem;
		margin: 0;
		color: var(--cc-text-body);
		font-size: clamp(1.05rem, 1.5vw, 1.2rem);
		line-height: 1.65;
		text-wrap: pretty;
	}
	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.9rem 1.15rem;
		margin-top: 2rem;
	}
	.button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.55rem;
		min-height: 2.9rem;
		padding: 0.2rem 1.15rem;
		border: 1px solid var(--cc-border-strong);
		border-radius: 999px;
		font-family: var(--cc-font-heading);
		font-weight: 700;
		text-decoration: none;
		transition: background var(--cc-transition), border-color var(--cc-transition), color var(--cc-transition);
	}
	.button--primary {
		border-color: var(--cc-cta);
		background: var(--cc-cta);
		color: var(--cc-on-cta);
	}
	.button--primary:hover {
		border-color: var(--cc-cta-hover);
		background: var(--cc-cta-hover);
	}
	:global(body.theme-paper) .button--primary {
		color: var(--cc-on-cta);
	}
	.text-link {
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
		min-height: 2.75rem;
		color: var(--cc-text-body);
		font-weight: 700;
		text-decoration-color: color-mix(in srgb, var(--cc-text-body) 42%, transparent);
		text-underline-offset: 0.28rem;
	}
	.text-link:hover { color: var(--cc-layer-team); }
	.hero-facts {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem 1.2rem;
		margin: 1.5rem 0 0;
		padding: 0;
		list-style: none;
		color: var(--cc-text-muted);
		font-size: 0.8rem;
	}
	.hero-facts li {
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}
	.hero-facts li::before {
		content: '';
		width: 0.35rem;
		height: 0.35rem;
		border-radius: 50%;
		background: var(--cc-layer-team);
	}
	.hero-facts a { color: inherit; }

	.app-preview {
		margin: 0;
		border: 1px solid var(--cc-border-strong);
		border-radius: 16px;
		background: var(--cc-surface-solid);
		overflow: hidden;
	}
	.window-bar {
		display: flex;
		align-items: center;
		gap: 0.42rem;
		min-height: 2.35rem;
		padding: 0 0.9rem;
		border-bottom: 1px solid var(--cc-border);
		background: var(--cc-surface-raised);
	}
	.window-bar > span {
		width: 0.58rem;
		height: 0.58rem;
		border-radius: 50%;
		background: var(--cc-text-faint);
		opacity: 0.55;
	}
	.window-bar strong {
		margin-left: auto;
		color: var(--cc-text-muted);
		font-size: 0.72rem;
		font-weight: 500;
	}
	.app-shell-preview {
		display: grid;
		grid-template-columns: 8.5rem minmax(0, 1fr);
		min-height: 23rem;
	}
	.preview-sidebar {
		display: flex;
		flex-direction: column;
		gap: 0.35rem;
		padding: 1.2rem 0.85rem;
		border-right: 1px solid var(--cc-border);
		background: color-mix(in srgb, var(--cc-canvas) 56%, var(--cc-surface-solid));
		color: var(--cc-text-muted);
		font-size: 0.72rem;
	}
	.preview-sidebar strong {
		margin: 0 0.35rem 0.8rem;
		color: var(--cc-text);
		font-size: 0.82rem;
	}
	.preview-sidebar span { padding: 0.48rem 0.55rem; border-radius: 7px; }
	.preview-sidebar .active { background: var(--cc-surface-soft); color: var(--cc-text); }
	.preview-content { padding: clamp(1.3rem, 3vw, 2.2rem); }
	.preview-content > p,
	.route-heading > span,
	.resolver-proof > div > span {
		margin: 0;
		color: var(--cc-layer-team);
		font-family: var(--cc-font-mono);
		font-size: 0.68rem;
		font-weight: 700;
	}
	.preview-content h2 {
		margin: 0.45rem 0 1.25rem;
		font-size: clamp(1.35rem, 2.6vw, 1.8rem);
		letter-spacing: -0.025em;
	}
	.folder-choice {
		display: grid;
		grid-template-columns: auto minmax(0, 1fr) auto;
		align-items: center;
		gap: 0.75rem;
		padding: 0.9rem;
		border: 1px solid color-mix(in srgb, var(--cc-layer-team) 60%, var(--cc-border));
		border-radius: 10px;
		background: color-mix(in srgb, var(--cc-layer-team) 9%, var(--cc-surface));
		color: var(--cc-layer-team);
	}
	.folder-choice div { display: grid; gap: 0.12rem; }
	.folder-choice strong { color: var(--cc-text); font-size: 0.85rem; }
	.folder-choice span { color: var(--cc-text-muted); font-size: 0.7rem; }
	.folder-choice .selected-mark {
		display: grid;
		place-items: center;
		width: 1.4rem;
		height: 1.4rem;
		border-radius: 50%;
		background: var(--cc-layer-team);
		color: var(--cc-canvas);
		font-weight: 700;
	}
	.preview-success {
		display: flex;
		align-items: center;
		gap: 0.7rem;
		margin-top: 0.8rem;
		padding: 0.8rem 0.9rem;
		border-bottom: 1px solid var(--cc-border);
	}
	.preview-success > span {
		width: 0.5rem;
		height: 0.5rem;
		border-radius: 50%;
		background: var(--cc-layer-team);
	}
	.preview-success div { display: grid; gap: 0.05rem; }
	.preview-success strong { color: var(--cc-text); font-size: 0.78rem; }
	.preview-success small { color: var(--cc-text-muted); }
	.preview-action {
		display: flex;
		align-items: center;
		justify-content: space-between;
		width: 100%;
		min-height: 2.6rem;
		margin-top: 1rem;
		padding: 0 0.9rem;
		border-radius: 9px;
		background: var(--cc-cta);
		color: var(--cc-on-cta);
		font-size: 0.8rem;
		font-weight: 700;
	}
	.app-preview figcaption {
		padding: 0.7rem 1rem;
		border-top: 1px solid var(--cc-border);
		color: var(--cc-text-faint);
		font-size: 0.68rem;
		text-align: right;
	}

	.activation,
	.source-install,
	.trust {
		padding: 5.5rem 0;
		border-top: 1px solid var(--cc-border);
	}
	.section-intro {
		display: flex;
		align-items: end;
		justify-content: space-between;
		gap: 2rem;
		margin-bottom: 3rem;
	}
	.section-intro h2 {
		max-width: 15ch;
		margin: 0;
		font-size: clamp(2.2rem, 5vw, 4.5rem);
		line-height: 1;
		letter-spacing: -0.035em;
		text-wrap: balance;
	}
	.section-intro > p {
		max-width: 28rem;
		margin: 0;
		color: var(--cc-text-muted);
		line-height: 1.65;
	}
	.activation-steps {
		margin: 0;
		padding: 0;
		list-style: none;
	}
	.activation-steps > li {
		display: grid;
		grid-template-columns: 3.2rem minmax(15rem, 0.72fr) minmax(20rem, 1.28fr);
		gap: clamp(1.25rem, 4vw, 3.5rem);
		align-items: start;
		padding: 2.25rem 0;
		border-top: 1px solid var(--cc-border);
	}
	.activation-steps > li:last-child { padding-bottom: 0; }
	.step-number {
		display: grid;
		place-items: center;
		width: 2.8rem;
		height: 2.8rem;
		border-radius: 10px;
		background: color-mix(in srgb, var(--cc-layer-team) 12%, var(--cc-surface));
		color: var(--cc-layer-team);
		font-family: var(--cc-font-mono);
		font-size: 0.75rem;
		font-weight: 700;
	}
	.step-copy h3 {
		margin: 0 0 0.65rem;
		font-size: 1.45rem;
		letter-spacing: -0.02em;
	}
	.step-copy p {
		margin: 0;
		color: var(--cc-text-muted);
		line-height: 1.65;
	}
	.step-copy :global(.code-block) { margin-top: 1.2rem; }
	.step-proof {
		align-self: center;
		border-top: 1px solid var(--cc-border-strong);
		border-bottom: 1px solid var(--cc-border-strong);
		background: var(--cc-surface-soft);
	}
	.source-proof { display: grid; gap: 0.25rem; padding: 1.1rem 1.25rem; }
	.source-proof span,
	.source-proof small {
		color: var(--cc-text-muted);
		font-family: var(--cc-font-mono);
		font-size: 0.68rem;
	}
	.source-proof strong { color: var(--cc-text); overflow-wrap: anywhere; }
	.client-proof { display: flex; flex-wrap: wrap; gap: 0.55rem; padding: 1rem; }
	.client-proof span {
		padding: 0.45rem 0.7rem;
		border-radius: 999px;
		background: var(--cc-surface-solid);
		color: var(--cc-text-body);
		font-size: 0.72rem;
	}
	.result-preview {
		margin: 0;
		padding: 1rem;
		border: 1px solid var(--cc-border);
		border-radius: 12px;
		background: var(--cc-surface-soft);
	}
	.result-header,
	.result-row,
	.conflict-row { display: grid; align-items: center; }
	.result-header {
		grid-template-columns: minmax(0, 1fr) auto;
		gap: 1rem;
		padding: 0.25rem 0.2rem 1rem;
	}
	.result-header div { display: grid; gap: 0.12rem; }
	.result-header span,
	.result-header h3,
	.result-row code,
	.conflict-row code { font-family: var(--cc-font-mono); }
	.result-header span {
		color: var(--cc-text-muted);
		font-size: 0.66rem;
		letter-spacing: 0.06em;
		text-transform: uppercase;
