---
import { fileURLToPath } from 'node:url';
import PackExplorer from '../../components/PackExplorer.astro';
import Base from '../../layouts/Base.astro';
import { loadPackExplorer } from '../../lib/pack-explorer';

const packRoot = fileURLToPath(
	new URL('../../../../../specs/contextcake-packs/packs/contextcake', import.meta.url),
);
const explorer = await loadPackExplorer(packRoot, 'contextcake');
const fileCount = explorer.files.length;
const folderCount = explorer.treeEntries.filter((entry) => entry.kind === 'dir').length;

const fitRows = [
	['Good fit', 'Developers and AI agents adopting or extending ContextCake.'],
	['Not for', 'Readers who just want the marketing overview; the rest of the site covers that.'],
	['Delivery', 'A complete Markdown Pack you can read and edit. Free forever.'],
];

const valuePoints = [
	'What ContextCake is and the mental model',
	'Architecture: sources, resolver, merge, conflicts',
	'Install, first cascade, and writing a layer',
	'MCP tools and connecting an AI agent',
];

const quickFacts = [
	['Creator', 'ContextCake'],
	['License', 'Free · MIT'],
	['Reviewed', 'July 17, 2026'],
	['Permissions', 'Content only'],
];

const featuredFiles = [
	{ label: 'Start here', path: 'START-HERE.md' },
	{ label: 'What it is', path: 'overview/what-is-contextcake.md' },
	{ label: 'Layers', path: 'architecture/layers-and-precedence.md' },
	{ label: 'Install', path: 'getting-started/installation.md' },
	{ label: 'Changelog', path: 'updates/CHANGELOG.md' },
];

const workflowSteps = [
	['01', 'Understand', 'Learn what ContextCake stores, how the layers work, and why resolution happens section by section.'],
	['02', 'Install', 'Get the dependency-free engine running on Node 18+ and resolve your first cascade.'],
	['03', 'Write a layer', 'Create OKF concepts with frontmatter and anchored sections that other layers can override.'],
	['04', 'Connect an agent', 'Run the MCP server and point Claude, Cursor, or any MCP client at the resolved graph.'],
];

const insideRows = [
	['Understand the architecture', 'Read how federated storage, the resolver, section merges, and provenance work together.'],
	['Connect an agent', 'Follow the MCP walkthrough or a tool-specific guide to use ContextCake in your repository.'],
	['Copy real examples', 'A full OKF concept, a working layers.json, and a resolved read_file payload with surfaced conflicts.'],
	['Avoid common mistakes', 'Check precedence, recency, the manifest trust boundary, conflict handling, and the dependency-free core.'],
];

const useCases = [
	['Adopting ContextCake', 'Add ContextCake to a repository and give your agent an accurate reference for the setup.'],
	['Onboarding a teammate', 'Someone new needs the architecture and conventions without reading the whole codebase.'],
	['Building on the engine', 'Extend sources, the resolver, or the MCP server with the architecture close at hand.'],
	['Explaining it to an AI tool', 'ChatGPT, Cursor, or Copilot should answer ContextCake questions accurately, not from stale guesses.'],
];

const compatRows = [
	['Plain files', 'Open and edit the Markdown in any text editor. No additional tool is required.'],
	['Claude Code', 'Add the ContextCake MCP server, or point Claude at the pack files.'],
	['ChatGPT', 'Upload the files as project or knowledge files, then reference them in prompts.'],
	['Cursor & Copilot', 'Keep the files in your repo so the assistant reads them as working context.'],
];

const faqs = [
	{
		q: 'Is this just the ContextCake docs?',
		a: 'The facts overlap with the documentation, but the Pack keeps them in files that can live inside a project and travel with an AI agent.',
	},
	{
		q: 'Do I need this to use ContextCake?',
		a: 'No. The engine works without this Pack. The Pack gives your assistant a local reference for setup, architecture, and common mistakes.',
	},
	{
		q: 'Is it accurate to the current version?',
		a: 'It was reviewed on July 17, 2026 against the current design spec and docs. Every release keeps a visible freshness date and changelog so you can make that judgment before installing.',
	},
	{
		q: 'What becomes paid later?',
		a: 'Not this Pack. ContextCake Pro will charge for managed sync and updates, and other professional Packs may be separate purchases. Pro is never required to install a Pack.',
	},
];
---

<Base
	title="ContextCake Context Pack"
	description="A free ContextCake Pack covering setup, architecture, OKF, the resolver, MCP tools, examples, and common mistakes."
>
	<main class="pack-page">
		<section class="hero" aria-labelledby="hero-title">
			<div class="hero-copy">
				<p class="eyebrow">ContextCake Pack</p>
				<h1 id="hero-title">Keep the ContextCake reference inside your project.</h1>
				<p class="lede">
					This free Pack covers the architecture, OKF format, resolver, MCP tools, setup,
					and examples. Put the files in your project so your assistant can reference them.
				</p>
				<div class="hero-actions" aria-label="Primary actions">
					<a class="button primary" href="#explorer">Read the pack free</a>
					<a class="button" href="#availability">License &amp; updates</a>
				</div>
				<dl class="quick-facts" aria-label="Pack quick facts">
					{quickFacts.map(([term, body]) => (
						<div>
							<dt>{term}</dt>
							<dd>{body}</dd>
						</div>
					))}
				</dl>
				<ul class="value-list" aria-label="What the pack includes">
					{valuePoints.map((item) => <li>{item}</li>)}
				</ul>
			</div>

			<aside class="summary-panel" aria-label="Pack fit summary">
				<p class="panel-label">At a glance</p>
				<dl class="fit-list">
					{fitRows.map(([term, body]) => (
						<div>
							<dt>{term}</dt>
							<dd>{body}</dd>
						</div>
					))}
				</dl>
			</aside>
		</section>

		<section class="workflow" aria-labelledby="workflow-title">
			<div class="section-head">
				<div>
					<p class="eyebrow">Suggested order</p>
					<h2 id="workflow-title">Read the model, run it, then connect an agent.</h2>
				</div>
				<p>
					The files start with the layer model, move through installation and authoring,
					and finish with the MCP connection.
				</p>
			</div>
			<ol class="workflow-grid" aria-label="The adoption arc">
				{workflowSteps.map(([num, title, body]) => (
					<li class="step">
						<span class="step-num" aria-hidden="true">{num}</span>
						<h3>{title}</h3>
						<p>{body}</p>
					</li>
				))}
			</ol>
		</section>

		<section id="explorer" class="explorer-section" aria-labelledby="explorer-title">
			<div class="section-head">
				<div>
					<p class="eyebrow">Look inside</p>
					<h2 id="explorer-title">Read every file.</h2>
				</div>
				<p>
					Choose a file from the tree and switch between rendered Markdown and source.
					The featured files cover the shortest path through the Pack.
				</p>
			</div>
			<PackExplorer
				id="contextcake-pack-explorer"
				explorer={explorer}
				featuredFiles={featuredFiles}
				defaultFile="START-HERE.md"
				title="ContextCake pack explorer"
			/>
		</section>

		<section class="detail-band" aria-labelledby="pack-uses-title">
			<div class="detail-column">
				<div class="section-head compact-head">
					<div>
						<p class="eyebrow">Use it for</p>
						<h2 id="pack-uses-title">Where this Pack helps.</h2>
					</div>
				</div>
				<div class="case-grid">
					{useCases.map(([title, body]) => (
						<article>
							<h3>{title}</h3>
							<p>{body}</p>
						</article>
					))}
				</div>
			</div>

			<div class="detail-column">
				<div class="section-head compact-head">
					<div>
						<p class="eyebrow">What’s inside</p>
						<h2 id="inside-title">What the Pack covers.</h2>
					</div>
				</div>
				<dl class="inside-list">
					{insideRows.map(([term, body]) => (
						<div>
							<dt>{term}</dt>
							<dd>{body}</dd>
						</div>
					))}
				</dl>
			</div>
		</section>

		<section id="availability" class="pricing" aria-labelledby="pricing-title">
			<div class="section-head">
				<div>
					<p class="eyebrow">Availability</p>
					<h2 id="pricing-title">Free to read, install, and keep.</h2>
				</div>
				<p>
					This first-party Pack and its corrections stay free. Other professional Packs are
					separate products; buying or installing one will never require Pro.
				</p>
			</div>

			<div class="plan-grid">
				<article class="plan plan-primary">
					<p class="card-label">Free Pack</p>
					<p class="price">
						<span class="price-amount">Free</span>
						<span class="price-suffix">forever</span>
					</p>
					<p class="cadence">Full Pack · corrections included · no account</p>
					<h3>ContextCake Context Pack</h3>
					<p class="plan-body">All {fileCount} files across {folderCount} directories, with its source disclosure, rights attestation, permission declaration, freshness date, and changelog visible before use.</p>
					<a class="button primary" href="#explorer">Read the full pack</a>
				</article>
				<article class="plan">
					<p class="card-label">Coming soon</p>
					<p class="price">
						<span class="price-amount">More</span>
						<span class="price-suffix">packs, later</span>
					</p>
					<p class="cadence">Separately licensed professional workflow Packs.</p>
					<h3>Additional Packs</h3>
					<p class="plan-body">Buy once and retain every delivered version. Optional editorial update subscriptions stop future releases when canceled; they never disable files you already received.</p>
					<a class="button" href="/packs">Browse Packs</a>
				</article>
			</div>

			<p class="pricing-note">No checkout is attached to this Pack. Its content, license, file tree, sample files, and changelog are available above.</p>
		</section>

		<section class="compatibility" aria-labelledby="compat-title">
			<div class="section-head compact-head">
				<div>
					<p class="eyebrow">Works with your tools</p>
					<h2 id="compat-title">Use the files directly or through your preferred tool.</h2>
				</div>
			</div>
			<dl class="compat-grid">
				{compatRows.map(([term, body]) => (
					<div>
						<dt>{term}</dt>
						<dd>{body}</dd>
					</div>
				))}
			</dl>
		</section>

		<section class="faq" aria-labelledby="faq-title">
			<div class="section-head">
				<div>
					<p class="eyebrow">FAQ</p>
					<h2 id="faq-title">Common questions.</h2>
				</div>
			</div>
			<div class="faq-list">
				{faqs.map((item) => (
					<details>
						<summary>{item.q}</summary>
						<p>{item.a}</p>
					</details>
				))}
			</div>
		</section>

		<section class="credibility" aria-label="About ContextCake">
			<p>
				Made and reviewed by <strong>ContextCake</strong>. Pack Contract v1 · content only ·
				no scripts, network access, credentials, or hidden services.
			</p>
			<a class="view-link" href="/pricing">See app pricing</a>
		</section>
	</main>
</Base>

<style>
	.pack-page {
		max-width: 76rem;
		margin: 0 auto;
		padding: 2.5rem 1.5rem 2rem;
	}
	.hero {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(18rem, 23rem);
		gap: 1.2rem;
		align-items: start;
		padding: 0.75rem 0 2rem;
		border-bottom: 1px solid var(--cc-border);
	}
	.eyebrow,
	.panel-label,
	.card-label {
		margin: 0 0 0.75rem;
		color: var(--cc-layer-team);
		font-family: var(--cc-font-mono);
		font-size: 0.78rem;
		font-weight: 700;
		letter-spacing: 0;
		text-transform: uppercase;
	}
	h1, h2, h3, p { letter-spacing: 0; }
	h1 {
		max-width: 14ch;
		margin: 0;
		font-size: clamp(2rem, 3vw, 3rem);
		line-height: 0.98;
	}
	.lede,
	.section-head > p:last-child,
	.fit-list dd,
	.case-grid p,
	.inside-list dd,
	.plan-body,
	.compat-grid dd,
	.faq p {
		color: var(--cc-text-body);
		line-height: 1.62;
	}
	.lede {
		max-width: 58ch;
		margin: 0.95rem 0 0;
		font-size: 1.08rem;
	}
	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.8rem;
		margin-top: 1.25rem;
	}
	.quick-facts {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 0.65rem;
		margin: 1rem 0 0;
	}
	.quick-facts div {
		padding: 0.8rem 0.85rem;
		border: 1px solid var(--cc-border);
		border-radius: var(--cc-radius-md);
		background: color-mix(in srgb, var(--cc-surface) 70%, transparent);
	}
	.quick-facts dt {
		margin: 0;
		color: var(--cc-layer-team);
		font-family: var(--cc-font-mono);
		font-size: 0.72rem;
		font-weight: 700;
		text-transform: uppercase;
	}
	.quick-facts dd {
		margin: 0.35rem 0 0;
		color: var(--cc-text);
		font-size: 0.94rem;
		font-weight: 700;
		line-height: 1.35;
	}
	.button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 44px;
		padding: 0 1rem;
		border: 1px solid var(--cc-border);
		border-radius: 6px;
		color: var(--cc-text);
		font-weight: 700;
		text-decoration: none;
	}
	.button.primary {
		border-color: var(--cc-cta);
		background: var(--cc-cta);
		color: var(--cc-on-cta);
	}
	.button.coming-soon {
		border-style: dashed;
		color: var(--cc-text-body);
		opacity: 0.7;
		cursor: default;
	}
	.value-list {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.55rem 1rem;
		margin: 1rem 0 0;
		padding: 0;
		list-style: none;
		max-width: 48rem;
	}
	.value-list li { color: var(--cc-text-body); }
	.value-list li::before {
		content: '';
		display: inline-block;
		width: 0.5rem;
		height: 0.5rem;
		margin-right: 0.55rem;
		border-radius: 2px;
		background: var(--cc-layer-personal);
		vertical-align: 0.08em;
	}
	.summary-panel {
		padding: 1rem;
		border: 1px solid var(--cc-border);
		border-radius: var(--cc-radius-md);
		background: color-mix(in srgb, var(--cc-surface) 82%, transparent);
		box-shadow: var(--cc-shadow-panel);
	}
	.fit-list { display: grid; gap: 0.85rem; margin: 0; }
	.fit-list div { display: grid; gap: 0.18rem; }
	.fit-list dt { color: var(--cc-text); font-weight: 700; }
	.fit-list dd { margin: 0; font-size: 0.98rem; }
	.workflow,
	.explorer-section,
	.detail-band,
	.pricing,
	.compatibility,
	.faq {
		padding: 2.25rem 0 0;
	}
	.section-head {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(0, 0.88fr);
		gap: 1.4rem;
		align-items: end;
		margin-bottom: 1.25rem;
	}
	.section-head h2 {
		max-width: 16ch;
		margin: 0;
		font-size: clamp(1.45rem, 2vw, 2.05rem);
		line-height: 1.04;
	}
	.section-head > p:last-child { margin: 0; font-size: 1rem; }
	.compact-head { margin-bottom: 1rem; }
	.compact-head .section-head > p:last-child { display: none; }
	.workflow-grid {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 0.9rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}
	.step {
		padding: 1.1rem 1rem 1.2rem;
		border: 1px solid var(--cc-border);
		border-top: 4px solid var(--cc-layer-team);
		border-radius: var(--cc-radius-md);
		background: color-mix(in srgb, var(--cc-surface) 72%, transparent);
	}
	.workflow-grid li:nth-child(2) { border-top-color: var(--cc-layer-company); }
	.workflow-grid li:nth-child(2) .step-num { color: var(--cc-layer-company); }
	.workflow-grid li:nth-child(3) { border-top-color: var(--cc-layer-personal); }
	.workflow-grid li:nth-child(3) .step-num { color: var(--cc-layer-personal); }
	.workflow-grid li:nth-child(4) { border-top-color: var(--cc-cta); }
	.workflow-grid li:nth-child(4) .step-num { color: var(--cc-cta); }
	.step-num {
		display: block;
		color: var(--cc-layer-team);
		font-family: var(--cc-font-mono);
		font-size: 0.92rem;
		font-weight: 700;
	}
	.step h3 { margin: 0.5rem 0 0; color: var(--cc-text); font-size: 1.12rem; }
	.step p { margin: 0.5rem 0 0; font-size: 0.95rem; }
	.detail-band {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1.1rem;
		align-items: start;
	}
	.detail-column { min-width: 0; }
	.case-grid { display: grid; gap: 0.9rem; grid-template-columns: 1fr; }
	.case-grid article {
		padding: 1rem;
		border: 1px solid var(--cc-border);
		border-radius: var(--cc-radius-md);
		background: color-mix(in srgb, var(--cc-surface) 72%, transparent);
		border-top: 4px solid var(--cc-layer-team);
	}
	.case-grid article:nth-child(2) { border-top-color: var(--cc-layer-company); }
	.case-grid article:nth-child(3) { border-top-color: var(--cc-layer-personal); }
	.case-grid article:nth-child(4) { border-top-color: var(--cc-cta); }
	.case-grid h3 { margin: 0; color: var(--cc-text); font-size: 1.12rem; }
	.case-grid p { margin: 0.55rem 0 0; font-size: 0.98rem; }
	.inside-list { display: grid; gap: 0.85rem; margin: 0; }
	.inside-list div {
		display: grid;
		gap: 0.2rem;
		padding: 0 0 0.85rem;
		border-bottom: 1px solid var(--cc-border);
	}
	.inside-list div:last-child { padding-bottom: 0; border-bottom: 0; }
	.inside-list dt { color: var(--cc-text); font-weight: 700; }
	.inside-list dd { margin: 0; font-size: 0.98rem; }
	.plan-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
	}
	.plan {
		display: flex;
		flex-direction: column;
		padding: 1.25rem 1.2rem 1.35rem;
		border: 1px solid var(--cc-border);
		border-radius: var(--cc-radius-md);
		background: color-mix(in srgb, var(--cc-surface) 74%, transparent);
	}
	.plan-primary {
		border-color: color-mix(in srgb, var(--cc-cta) 55%, var(--cc-border));
		box-shadow: var(--cc-shadow-panel);
	}
	.price {
		display: flex;
		align-items: baseline;
		gap: 0.4rem;
		margin: 0.2rem 0 0;
	}
	.price-amount { color: var(--cc-text); font-size: 2rem; font-weight: 700; line-height: 1; }
	.price-suffix {
		color: var(--cc-text-body);
		font-family: var(--cc-font-mono);
		font-size: 0.8rem;
		text-transform: uppercase;
		letter-spacing: 0;
	}
	.cadence { margin: 0.4rem 0 0; color: var(--cc-text-body); font-size: 0.9rem; }
	.plan h3 { margin: 0.75rem 0 0; color: var(--cc-text); font-size: 1.1rem; }
	.plan-body { margin: 0.5rem 0 0; font-size: 0.98rem; }
	.plan .button { margin-top: 1.1rem; width: fit-content; }
	.pricing-note { margin: 1rem 0 0; color: var(--cc-text-body); font-size: 0.94rem; }
	.compat-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.85rem 1.1rem;
		margin: 0;
	}
	.compat-grid div {
		display: grid;
		gap: 0.2rem;
		padding: 0.9rem 1rem;
		border: 1px solid var(--cc-border);
		border-radius: var(--cc-radius-md);
		background: color-mix(in srgb, var(--cc-surface) 70%, transparent);
	}
	.compat-grid dt { color: var(--cc-text); font-weight: 700; }
	.compat-grid dd { margin: 0; font-size: 0.96rem; }
	.faq-list { display: grid; gap: 0.6rem; }
	details { padding: 1rem 0; border-top: 1px solid var(--cc-border); }
	summary { color: var(--cc-text); cursor: pointer; font-weight: 700; }
	.credibility {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: space-between;
		gap: 0.75rem 1.5rem;
		margin-top: 2.5rem;
		padding: 1.25rem 0 0;
		border-top: 1px solid var(--cc-border);
	}
	.credibility p {
		max-width: 52ch;
		margin: 0;
		color: var(--cc-text-body);
		line-height: 1.55;
	}
	.credibility strong { color: var(--cc-text); }
	.view-link {
		display: inline-flex;
		align-items: center;
		min-height: 44px;
		color: var(--cc-text);
		font-weight: 700;
		text-decoration-thickness: 1px;
		text-underline-offset: 0.24em;
	}
	@media (max-width: 920px) {
		.hero, .section-head, .detail-band { grid-template-columns: 1fr; }
		.workflow-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
		.quick-facts { grid-template-columns: repeat(2, minmax(0, 1fr)); }
	}
	@media (max-width: 620px) {
		.pack-page { padding-top: 2rem; }
		.workflow-grid, .plan-grid, .compat-grid, .quick-facts { grid-template-columns: 1fr; }
		.value-list { grid-template-columns: 1fr; }
	}
</style>
