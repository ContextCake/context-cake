---
// Copy-to-clipboard command box (spec.md: homepage AC 1–2).
import { codeToHtml } from 'shiki';
import Icon from './Icon.astro';

interface Props {
	command: string;
}
const { command } = Astro.props;
const html = await codeToHtml(`$ ${command}`, {
	lang: 'bash',
	theme: 'github-dark-default',
});
---

<div class="copy-command">
	<div class="command-view" set:html={html} />
	<button type="button" data-command={command} aria-label="Copy command to clipboard">
		<Icon name="copy" size={16} />
		<span class="label">Copy</span>
	</button>
</div>

<style>
	.copy-command {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.75rem 1rem;
		max-width: 100%;
		background: var(--cc-surface);
		border: 1px solid var(--cc-border);
		border-radius: var(--cc-radius-md);
		padding: 0.75rem 1rem;
		font-family: var(--cc-font-mono);
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.035);
	}
	.command-view {
		flex: 1 1 auto;
		min-width: 0;
	}
	button {
		flex: 0 0 auto;
	}
	.command-view :global(.shiki) {
		margin: 0;
		padding: 0;
		background: transparent !important;
		font-family: var(--cc-font-mono);
		font-size: 0.96rem;
		line-height: 1.55;
		overflow-wrap: anywhere;
		white-space: pre-wrap;
	}
	.command-view :global(.shiki code) {
		white-space: pre-wrap;
		word-break: break-word;
	}
	button {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		background: transparent;
		border: 1px solid var(--cc-border);
		border-radius: 999px;
		color: var(--cc-text-body);
		font-family: var(--cc-font-mono);
		font-size: 0.85rem;
		min-height: 34px;
		padding: 0.35rem 0.8rem;
		cursor: pointer;
		transition: color var(--cc-transition), border-color var(--cc-transition);
	}
	button:hover {
		color: var(--cc-text);
		border-color: var(--cc-cta);
	}
	button.copied {
		color: var(--cc-cta);
		border-color: var(--cc-cta);
	}
</style>

<script>
	async function copyText(text: string): Promise<boolean> {
		try {
			if (navigator.clipboard && window.isSecureContext) {
				await navigator.clipboard.writeText(text);
				return true;
			}
		} catch {
			/* fall through to the select-to-copy fallback */
		}
		return false;
	}

	// Graceful fallback when the Clipboard API is unavailable (insecure context,
	// permission denied, older browser): select the command text in the visible
	// code view so the user can copy it themselves (Cmd/Ctrl-C).
	function selectCommandText(button: HTMLButtonElement) {
		const view = button
			.closest('.copy-command')
			?.querySelector<HTMLElement>('.command-view code');
		if (!view) return;
		const selection = window.getSelection();
		if (!selection) return;
		const range = document.createRange();
		range.selectNodeContents(view);
		selection.removeAllRanges();
		selection.addRange(range);
	}

	for (const button of document.querySelectorAll<HTMLButtonElement>('.copy-command button')) {
		button.addEventListener('click', async () => {
			const ok = await copyText(button.dataset.command ?? '');
			const label = button.querySelector('.label');
			if (ok) {
				button.classList.add('copied');
				if (label) label.textContent = 'Copied';
			} else {
				selectCommandText(button);
				if (label) label.textContent = 'Selected — press ⌘/Ctrl-C';
			}
			setTimeout(() => {
				button.classList.remove('copied');
				if (label) label.textContent = 'Copy';
			}, 2000);
		});
	}
</script>
