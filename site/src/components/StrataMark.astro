---
// The logo mark: three offset strata in the layer colors, top to bottom
// personal / team / company — same semantics as everywhere else on the site.
interface Props {
	size?: number;
}
const { size = 24 } = Astro.props;
---

<svg
	width={size}
	height={size}
	viewBox="0 0 24 24"
	fill="none"
	xmlns="http://www.w3.org/2000/svg"
	aria-hidden="true"
>
	<rect x="6" y="3" width="14" height="5" rx="1.5" style="fill: var(--cc-layer-personal)"></rect>
	<rect x="3" y="10" width="16" height="5" rx="1.5" style="fill: var(--cc-layer-team)"></rect>
	<rect x="5" y="17" width="17" height="5" rx="1.5" style="fill: var(--cc-layer-company)"></rect>
</svg>
