---
import Base from '../layouts/Base.astro';
---

<Base
	title="ContextCake demo"
	description="Explore the ContextCake console on the main site: layer views, resolved concepts, conflict inspection, and the interactive cascade canvas."
>
	<main class="demo-page">
		<section class="demo-shell" aria-labelledby="demo-title">
			<div class="demo-copy">
				<p class="eyebrow">Live demo</p>
				<h1 id="demo-title">The console runs here now.</h1>
				<p>
					This is the same ContextCake console, served from the main site instead of a separate
					domain. Open it full-screen or use it in place below.
				</p>
				<div class="actions">
					<a class="button primary" href="/demo-app/" target="_blank" rel="noreferrer">Open full demo</a>
					<a class="button" href="/docs/getting-started/first-cascade">Read the first-cascade guide</a>
				</div>
			</div>
			<div class="frame-wrap">
				<iframe
					class="demo-frame"
					src="/demo-app/"
					title="ContextCake console demo"
					loading="eager"
				/>
			</div>
		</section>
	</main>
</Base>

<style>
	.demo-page {
		max-width: 76rem;
		margin: 0 auto;
		padding: 2.5rem 1.5rem 2rem;
	}
	.demo-shell {
		display: grid;
		gap: 1.25rem;
	}
	.eyebrow {
		margin: 0 0 0.75rem;
		color: var(--cc-layer-team);
		font-family: var(--cc-font-mono);
		font-size: 0.78rem;
		font-weight: 700;
		letter-spacing: 0;
		text-transform: uppercase;
	}
	h1,
	p {
		letter-spacing: 0;
	}
	h1 {
		margin: 0;
		max-width: 12ch;
		font-size: clamp(2.1rem, 4vw, 3.4rem);
		line-height: 0.96;
		color: var(--cc-text);
	}
	.demo-copy p:last-of-type {
		max-width: 62ch;
		margin: 0.95rem 0 0;
		color: var(--cc-text-body);
		font-size: 1.06rem;
		line-height: 1.62;
	}
	.actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.8rem;
		margin-top: 1.2rem;
	}
	.button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 44px;
		padding: 0 1rem;
		border: 1px solid var(--cc-border);
		border-radius: 6px;
		color: var(--cc-text);
		font-weight: 700;
		text-decoration: none;
	}
	.button.primary {
		border-color: var(--cc-cta);
		background: var(--cc-cta);
		color: var(--cc-on-cta);
	}
	.frame-wrap {
		overflow: hidden;
		border: 1px solid var(--cc-border);
		border-radius: var(--cc-radius-lg);
		background: color-mix(in srgb, var(--cc-surface) 82%, transparent);
		box-shadow: var(--cc-shadow-panel);
	}
	.demo-frame {
		display: block;
		width: 100%;
		min-height: 78vh;
		border: 0;
		background: #0f1115;
	}
	@media (max-width: 620px) {
		.demo-page {
			padding-top: 2rem;
		}
		.demo-frame {
			min-height: 72vh;
		}
	}
</style>
