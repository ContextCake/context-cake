---
import { fileURLToPath } from 'node:url';
import PackExplorer from '../../components/PackExplorer.astro';
import Base from '../../layouts/Base.astro';
import { loadPackExplorer } from '../../lib/pack-explorer';

const packRoot = fileURLToPath(
	new URL(
		'../../../../specs/contextcake-packs/private-repo-template/packs/data-analytics-team',
		import.meta.url,
	),
);
const explorer = await loadPackExplorer(packRoot, 'data-analytics-team');
const fileCount = explorer.files.length;
const folderCount = explorer.treeEntries.filter((entry) => entry.kind === 'dir').length;

// Stripe Payment Links — placeholders until Stripe setup (Phase 7) is done.
// Replace these two constants with the real buy.stripe.com links and set checkoutLive = true.
const STRIPE_BASE_PACK_URL = 'https://buy.stripe.com/REPLACE_WITH_BASE_PACK_LINK';
const STRIPE_UPDATES_URL = 'https://buy.stripe.com/REPLACE_WITH_UPDATES_LINK';
const checkoutLive = false;

const fitRows = [
	['Good fit', 'Small in-house data and analytics teams handling recurring stakeholder requests.'],
	['Not for', 'Teams shopping for a BI tool, warehouse connector, or live metrics product.'],
	['Delivery', 'Plain markdown files first, with Claude Code plugin packaging included.'],
];

const valuePoints = [
	'Clarification workflow for vague requests',
	'Source-of-truth and validation rules',
	'Spec, checklist, and summary templates',
	'Local overlay guidance for team-specific edits',
];

const quickFacts = [
	['Files', `${fileCount} source files`],
	['Folders', `${folderCount} directories`],
	['Format', 'Markdown first'],
	['Overlay model', 'Base pack + local edits'],
];

const featuredFiles = [
	{ label: 'Start here', path: 'skills/data-analytics-team-pack/START-HERE.md' },
	{ label: 'Request flow', path: 'skills/data-analytics-team-pack/workflows/request-clarification.md' },
	{ label: 'Spec template', path: 'skills/data-analytics-team-pack/templates/clarified-spec-template.md' },
	{ label: 'Source rules', path: 'skills/data-analytics-team-pack/policies-and-rules/source-of-truth-precedence.md' },
];

const workflowSteps = [
	['01', 'Clarify', 'Turn a vague ask into a written spec: the real question, the metric definition, the source of truth, and what “done” means.'],
	['02', 'Build', 'Produce the query, model, or report against the agreed definition — not a guess at what was meant.'],
	['03', 'Validate', 'Reconcile the result to the source of truth before it ships. Catch the wrong number before the stakeholder does.'],
	['04', 'Deliver', 'Send an insight summary: the answer, its confidence, the caveats, and a clear next action — not just a screenshot.'],
];

const insideRows = [
	['Answer the same request faster', 'A clarification workflow and spec template that stop the back-and-forth on vague asks.'],
	['Keep numbers consistent', 'Source-of-truth and metric-definition rules so two people report the same figure the same way.'],
	['Ship results you can defend', 'A validation checklist and insight-summary template that make caveats and confidence explicit.'],
	['Keep your own edits separate', 'Local overlay guidance so team-specific rules live outside the pack and survive updates.'],
];

const useCases = [
	['Dashboard requests', 'When the same stakeholder question shows up every week with slightly different framing.'],
	['Analyst onboarding', 'When new team members need the team’s standards without digging through old chats.'],
	['AI drafting guardrails', 'When Claude, ChatGPT, Cursor, or Copilot can draft the work but still need team rules.'],
	['Insight delivery', 'When the answer needs caveats, confidence, and a clear next action, not just a screenshot.'],
];

const pricingPlans = [
	{
		label: 'Base pack',
		cadence: 'One-time purchase',
		note: 'Yours to keep',
		title: 'Data & Analytics Teams pack',
		body: 'The full pack: workflows, templates, examples, policies, and tool guides your team keeps rebuilding in chat. Delivered as plain files plus Claude Code packaging.',
		href: STRIPE_BASE_PACK_URL,
		link: 'Get the base pack',
		primary: true,
	},
	{
		label: 'Optional updates',
		cadence: 'Monthly subscription',
		note: 'Cancel anytime',
		title: 'Curated updates',
		body: 'Sharper examples and improved guidance shipped as reviewable editorial releases. Optional — the base pack keeps working on its own.',
		href: STRIPE_UPDATES_URL,
		link: 'Add monthly updates',
		primary: false,
	},
];

const compatRows = [
	['Plain files', 'Markdown you can open, read, and edit anywhere. This is the baseline — no tool required.'],
	['Claude Code', 'Install as a plugin, or point Claude at the unzipped files.'],
	['ChatGPT', 'Upload the files as project or knowledge files, then reference them in prompts.'],
	['Cursor & Copilot', 'Keep the files in your repo so the assistant reads them as working context.'],
];

const faqs = [
	{
		q: 'Is this a BI tool or data catalog?',
		a: 'No. It is a file-based working kit for analytics teams. It does not connect to your warehouse or manage live data.',
	},
	{
		q: 'Do we need any special software to use it?',
		a: 'No. The baseline deliverable is plain files you can read and edit in any editor. Claude Code packaging is included for teams that want it, but it is optional.',
	},
	{
		q: 'Can we customize it?',
		a: 'Yes. The intended model is to keep the base pack clean and put team-specific policies, examples, and exceptions in your own local overlay so updates stay easy to merge.',
	},
	{
		q: 'What do the optional updates include?',
		a: 'Curated editorial releases: clearer examples, sharper guidance, and new templates. They are sent separately from the base pack, and the base pack keeps working whether or not you subscribe.',
	},
];
---

<Base
	title="ContextCake Pack: Data & Analytics Teams"
	description="A file-based pack for data teams that need repeatable request scoping, validation, and insight delivery standards across AI tools."
>
	<main class="pack-page">
		<section class="hero" aria-labelledby="hero-title">
			<div class="hero-copy">
				<p class="eyebrow">ContextCake Pack</p>
				<h1 id="hero-title">A working kit for recurring analytics requests.</h1>
				<p class="lede">
					For teams that keep answering the same questions in slightly different ways:
					what was asked, which metric definition applies, how should we check the build,
					and how should the answer be written up.
				</p>
				<div class="hero-actions" aria-label="Primary actions">
					<a class="button primary" href="#pricing">See pricing</a>
					<a class="button" href="#explorer">Explore the files</a>
				</div>
				<dl class="quick-facts" aria-label="Pack quick facts">
					{quickFacts.map(([term, body]) => (
						<div>
							<dt>{term}</dt>
							<dd>{body}</dd>
						</div>
					))}
				</dl>
				<ul class="value-list" aria-label="What the pack includes">
					{valuePoints.map((item) => <li>{item}</li>)}
				</ul>
			</div>

			<aside class="summary-panel" aria-label="Pack fit summary">
				<p class="panel-label">At a glance</p>
				<dl class="fit-list">
					{fitRows.map(([term, body]) => (
						<div>
							<dt>{term}</dt>
							<dd>{body}</dd>
						</div>
					))}
				</dl>
			</aside>
		</section>

		<section class="workflow" aria-labelledby="workflow-title">
			<div class="section-head">
				<div>
					<p class="eyebrow">The workflow</p>
					<h2 id="workflow-title">One request, four steps.</h2>
				</div>
				<p>
					The pack is built around the path every request already takes — it just makes
					each step repeatable instead of improvised.
				</p>
			</div>
			<ol class="workflow-grid" aria-label="The four-step workflow">
				{workflowSteps.map(([num, title, body]) => (
					<li class="step">
						<span class="step-num" aria-hidden="true">{num}</span>
						<h3>{title}</h3>
						<p>{body}</p>
					</li>
				))}
			</ol>
		</section>

		<section id="explorer" class="explorer-section" aria-labelledby="explorer-title">
			<div class="section-head">
				<div>
					<p class="eyebrow">Look inside</p>
					<h2 id="explorer-title">Open the pack.</h2>
				</div>
				<p>
					File tree on the left, syntax-highlighted preview on the right. Start with the
					featured files if you just want the quick read.
				</p>
			</div>
			<PackExplorer
				id="data-analytics-pack-explorer"
				explorer={explorer}
				featuredFiles={featuredFiles}
				defaultFile="skills/data-analytics-team-pack/START-HERE.md"
				title="Data & Analytics Teams pack explorer"
			/>
		</section>

		<section class="detail-band" aria-labelledby="pack-uses-title">
			<div class="detail-column">
				<div class="section-head compact-head">
					<div>
						<p class="eyebrow">Use it for</p>
						<h2 id="pack-uses-title">What teams actually use it for.</h2>
					</div>
				</div>
				<div class="case-grid">
					{useCases.map(([title, body]) => (
						<article>
							<h3>{title}</h3>
							<p>{body}</p>
						</article>
					))}
				</div>
			</div>

			<div class="detail-column">
				<div class="section-head compact-head">
					<div>
						<p class="eyebrow">What’s inside</p>
						<h2 id="inside-title">What you get out of it.</h2>
					</div>
				</div>
				<dl class="inside-list">
					{insideRows.map(([term, body]) => (
						<div>
							<dt>{term}</dt>
							<dd>{body}</dd>
						</div>
					))}
				</dl>
			</div>
		</section>

		<section id="pricing" class="pricing" aria-labelledby="pricing-title">
			<div class="section-head">
				<div>
					<p class="eyebrow">Pricing</p>
					<h2 id="pricing-title">Buy once. Update if you want.</h2>
				</div>
				<p>
					The base pack is a one-time purchase you keep. Updates are a separate, optional
					monthly subscription — never required to use what you bought.
				</p>
			</div>
			<div class="plan-grid">
				{pricingPlans.map((plan) => (
					<article class={`plan${plan.primary ? ' plan-primary' : ''}`}>
						<p class="card-label">{plan.label}</p>
						<p class="cadence">
							<span class="cadence-main">{plan.cadence}</span>
							<span class="cadence-note">{plan.note}</span>
						</p>
						<h3>{plan.title}</h3>
						<p class="plan-body">{plan.body}</p>
						<a
							class={`button${plan.primary ? ' primary' : ''}`}
							href={plan.href}
							aria-disabled={checkoutLive ? undefined : 'true'}
						>
							{plan.link}
						</a>
					</article>
				))}
			</div>
			{!checkoutLive && (
				<p class="pricing-note">
					Checkout links go live just before the pilot — the buttons above are
					placeholders until Stripe is connected.
				</p>
			)}
		</section>

		<section class="compatibility" aria-labelledby="compat-title">
			<div class="section-head compact-head">
				<div>
					<p class="eyebrow">Works with your tools</p>
					<h2 id="compat-title">Plain files first. Everything else is a bonus.</h2>
				</div>
			</div>
			<dl class="compat-grid">
				{compatRows.map(([term, body]) => (
					<div>
						<dt>{term}</dt>
						<dd>{body}</dd>
					</div>
				))}
			</dl>
		</section>

		<section class="faq" aria-labelledby="faq-title">
			<div class="section-head">
				<div>
					<p class="eyebrow">FAQ</p>
					<h2 id="faq-title">Before you ask.</h2>
				</div>
			</div>
			<div class="faq-list">
				{faqs.map((item) => (
					<details>
						<summary>{item.q}</summary>
						<p>{item.a}</p>
					</details>
				))}
			</div>
		</section>

		<section class="credibility" aria-label="About ContextCake">
			<p>
				ContextCake Packs are made by <strong>ContextCake</strong>, the context layer that
				keeps team knowledge consistent across AI tools.
			</p>
			<a class="view-link" href="/">Learn about ContextCake</a>
		</section>
	</main>
</Base>

<style>
	.pack-page {
		max-width: 76rem;
		margin: 0 auto;
		padding: 2.5rem 1.5rem 2rem;
	}
	.hero {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(18rem, 23rem);
		gap: 1.2rem;
		align-items: start;
		padding: 0.75rem 0 2rem;
		border-bottom: 1px solid var(--cc-border);
	}
	.eyebrow,
	.panel-label,
	.card-label {
		margin: 0 0 0.75rem;
		color: var(--cc-layer-team);
		font-family: var(--cc-font-mono);
		font-size: 0.78rem;
		font-weight: 700;
		letter-spacing: 0;
		text-transform: uppercase;
	}
	h1,
	h2,
	h3,
	p {
		letter-spacing: 0;
	}
	h1 {
		max-width: 10ch;
		margin: 0;
		font-size: clamp(2rem, 3vw, 3rem);
		line-height: 0.98;
	}
	.lede,
	.section-head > p:last-child,
	.fit-list dd,
	.case-grid p,
	.inside-list dd,
	.plan-body,
	.compat-grid dd,
	.faq p {
		color: var(--cc-text-body);
		line-height: 1.62;
	}
	.lede {
		max-width: 58ch;
		margin: 0.95rem 0 0;
		font-size: 1.08rem;
	}
	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.8rem;
		margin-top: 1.25rem;
	}
	.quick-facts {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 0.65rem;
		margin: 1rem 0 0;
	}
	.quick-facts div {
		padding: 0.8rem 0.85rem;
		border: 1px solid var(--cc-border);
		border-radius: var(--cc-radius-md);
		background: color-mix(in srgb, var(--cc-surface) 70%, transparent);
	}
	.quick-facts dt {
		margin: 0;
		color: var(--cc-layer-team);
		font-family: var(--cc-font-mono);
		font-size: 0.72rem;
		font-weight: 700;
		text-transform: uppercase;
	}
	.quick-facts dd {
		margin: 0.35rem 0 0;
		color: var(--cc-text);
		font-size: 0.94rem;
		font-weight: 700;
		line-height: 1.35;
	}
	.button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 44px;
		padding: 0 1rem;
		border: 1px solid var(--cc-border);
		border-radius: 6px;
		color: var(--cc-text);
		font-weight: 700;
		text-decoration: none;
	}
	.button.primary {
		border-color: var(--cc-cta);
		background: var(--cc-cta);
		color: var(--cc-on-cta);
	}
	.button[aria-disabled='true'] {
		opacity: 0.55;
		cursor: not-allowed;
	}
	.value-list {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.55rem 1rem;
		margin: 1rem 0 0;
		padding: 0;
		list-style: none;
		max-width: 48rem;
	}
	.value-list li {
		color: var(--cc-text-body);
	}
	.value-list li::before {
		content: '';
		display: inline-block;
		width: 0.5rem;
		height: 0.5rem;
		margin-right: 0.55rem;
		border-radius: 2px;
		background: var(--cc-layer-personal);
		vertical-align: 0.08em;
	}
	.summary-panel {
		padding: 1rem;
		border: 1px solid var(--cc-border);
		border-radius: var(--cc-radius-md);
		background: color-mix(in srgb, var(--cc-surface) 82%, transparent);
		box-shadow: var(--cc-shadow-panel);
	}
	.fit-list {
		display: grid;
		gap: 0.85rem;
		margin: 0;
	}
	.fit-list div {
		display: grid;
		gap: 0.18rem;
	}
	.fit-list dt {
		color: var(--cc-text);
		font-weight: 700;
	}
	.fit-list dd {
		margin: 0;
		font-size: 0.98rem;
	}
	.workflow,
	.explorer-section,
	.detail-band,
	.pricing,
	.compatibility,
	.faq {
		padding: 2.25rem 0 0;
	}
	.section-head {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(0, 0.88fr);
		gap: 1.4rem;
		align-items: end;
		margin-bottom: 1.25rem;
	}
	.section-head h2 {
		max-width: 14ch;
		margin: 0;
		font-size: clamp(1.45rem, 2vw, 2.05rem);
		line-height: 1.04;
	}
	.section-head > p:last-child {
		margin: 0;
		font-size: 1rem;
	}
	.compact-head {
		margin-bottom: 1rem;
	}
	.compact-head .section-head > p:last-child {
		display: none;
	}
	.workflow-grid {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 0.9rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}
	.step {
		padding: 1.1rem 1rem 1.2rem;
		border: 1px solid var(--cc-border);
		border-top: 4px solid var(--cc-layer-team);
		border-radius: var(--cc-radius-md);
		background: color-mix(in srgb, var(--cc-surface) 72%, transparent);
	}
	.workflow-grid li:nth-child(2) { border-top-color: var(--cc-layer-company); }
	.workflow-grid li:nth-child(2) .step-num { color: var(--cc-layer-company); }
	.workflow-grid li:nth-child(3) { border-top-color: var(--cc-layer-personal); }
	.workflow-grid li:nth-child(3) .step-num { color: var(--cc-layer-personal); }
	.workflow-grid li:nth-child(4) { border-top-color: var(--cc-cta); }
	.workflow-grid li:nth-child(4) .step-num { color: var(--cc-cta); }
	.step-num {
		display: block;
		color: var(--cc-layer-team);
		font-family: var(--cc-font-mono);
		font-size: 0.92rem;
		font-weight: 700;
	}
	.step h3 {
		margin: 0.5rem 0 0;
		color: var(--cc-text);
		font-size: 1.12rem;
	}
	.step p {
		margin: 0.5rem 0 0;
		font-size: 0.95rem;
	}
	.detail-band {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1.1rem;
		align-items: start;
	}
	.detail-column {
		min-width: 0;
	}
	.case-grid {
		display: grid;
		gap: 0.9rem;
		grid-template-columns: 1fr;
	}
	.case-grid article {
		padding: 1rem;
		border: 1px solid var(--cc-border);
		border-radius: var(--cc-radius-md);
		background: color-mix(in srgb, var(--cc-surface) 72%, transparent);
		border-top: 4px solid var(--cc-layer-team);
	}
	.case-grid article:nth-child(2) {
		border-top-color: var(--cc-layer-company);
	}
	.case-grid article:nth-child(3) {
		border-top-color: var(--cc-layer-personal);
	}
	.case-grid article:nth-child(4) {
		border-top-color: var(--cc-cta);
	}
	.case-grid h3 {
		margin: 0;
		color: var(--cc-text);
		font-size: 1.12rem;
	}
	.case-grid p {
		margin: 0.55rem 0 0;
		font-size: 0.98rem;
	}
	.inside-list {
		display: grid;
		gap: 0.85rem;
		margin: 0;
	}
	.inside-list div {
		display: grid;
		gap: 0.2rem;
		padding: 0 0 0.85rem;
		border-bottom: 1px solid var(--cc-border);
	}
	.inside-list div:last-child {
		padding-bottom: 0;
		border-bottom: 0;
	}
	.inside-list dt {
		color: var(--cc-text);
		font-weight: 700;
	}
	.inside-list dd {
		margin: 0;
		font-size: 0.98rem;
	}
	.plan-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
	}
	.plan {
		display: flex;
		flex-direction: column;
		padding: 1.25rem 1.2rem 1.35rem;
		border: 1px solid var(--cc-border);
		border-radius: var(--cc-radius-md);
		background: color-mix(in srgb, var(--cc-surface) 74%, transparent);
	}
	.plan-primary {
		border-color: color-mix(in srgb, var(--cc-cta) 55%, var(--cc-border));
		box-shadow: var(--cc-shadow-panel);
	}
	.cadence {
		display: flex;
		flex-wrap: wrap;
		align-items: baseline;
		gap: 0.5rem;
		margin: 0.15rem 0 0;
	}
	.cadence-main {
		color: var(--cc-text);
		font-size: 1.2rem;
		font-weight: 700;
	}
	.cadence-note {
		color: var(--cc-text-body);
		font-family: var(--cc-font-mono);
		font-size: 0.76rem;
		text-transform: uppercase;
		letter-spacing: 0;
	}
	.plan h3 {
		margin: 0.75rem 0 0;
		color: var(--cc-text);
		font-size: 1.1rem;
	}
	.plan-body {
		margin: 0.5rem 0 0;
		font-size: 0.98rem;
	}
	.plan .button {
		margin-top: 1.1rem;
		width: fit-content;
	}
	.pricing-note {
		margin: 1rem 0 0;
		color: var(--cc-text-body);
		font-size: 0.94rem;
	}
	.compat-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.85rem 1.1rem;
		margin: 0;
	}
	.compat-grid div {
		display: grid;
		gap: 0.2rem;
		padding: 0.9rem 1rem;
		border: 1px solid var(--cc-border);
		border-radius: var(--cc-radius-md);
		background: color-mix(in srgb, var(--cc-surface) 70%, transparent);
	}
	.compat-grid dt {
		color: var(--cc-text);
		font-weight: 700;
	}
	.compat-grid dd {
		margin: 0;
		font-size: 0.96rem;
	}
	.faq-list {
		display: grid;
		gap: 0.6rem;
	}
	details {
		padding: 1rem 0;
		border-top: 1px solid var(--cc-border);
	}
	summary {
		color: var(--cc-text);
		cursor: pointer;
		font-weight: 700;
	}
